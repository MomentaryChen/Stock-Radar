# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=stockradar
POSTGRES_PASSWORD=stockradar
POSTGRES_DB=stockradar
POSTGRES_PORT=5432

# ── Service Ports ─────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Database Connection (used by backend app) ─────────────
DATABASE_URL=postgresql+asyncpg://stockradar:stockradar@localhost:5432/stockradar
DATABASE_URL_SYNC=postgresql://stockradar:stockradar@localhost:5432/stockradar

# ── Backend App Settings ──────────────────────────────────
MARKET_DATA_CACHE_TTL_MINUTES=30
TICKER_INFO_CACHE_TTL_HOURS=24
CORS_ORIGINS=["http://localhost:5173"]
DEFAULT_BENCHMARK=0050.TW
RISK_FREE_RATE=0.015
USAGE_ADMIN_TOKEN=please-change-this-token
USAGE_ADMIN_CLIENTS_LIMIT=100
